# A.M.Y environment variables — copy to .env and fill in real values.
# Do NOT commit .env to git.

# Ollama Cloud API key (required for LLM backend)
# Get yours at https://ollama.com
OLLAMA_CLOUD_API_KEY=your_ollama_api_key_here

# Optional: secondary key for failover
# OLLAMA_CLOUD_API_KEY_2=

# Optional: override Atlas actor identity for misuse-guard logs
# ATLAS_ACTOR_ID=amy_atlas_tools

# Optional: override base URL (default https://ollama.com)
# OLLAMA_BASE_URL=https://ollama.com
