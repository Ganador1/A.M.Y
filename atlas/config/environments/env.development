# AXIOM Development Environment Configuration
# Este archivo contiene configuraciones específicas para el entorno de desarrollo

# Server Configuration
DEBUG=true
RELOAD=true
HOST=127.0.0.1
PORT=8002

# Database Configuration
DATABASE_URL=postgresql://giovanniarangio@localhost:5432/axiom_dev
ENABLE_DATABASE=true
DB_ECHO=true

# Logging
LOG_LEVEL=DEBUG

# Security (Development - menos estricto)
ENABLE_AUTH_ROUTES=false
SECRET_KEY=dev-secret-key-not-for-production

# LLM Configuration
ENABLE_LOCAL_LLM=false
LLM_BACKEND=huggingface
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b
LLM_TEMPERATURE=0.3
LLM_MAX_NEW_TOKENS=256

# External APIs (Development - opcional)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# Observability (Development - habilitado para debugging)
ENABLE_OTEL=true
OTEL_SERVICE_NAME=axiom-dev
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
JAEGER_ENABLED=true
JAEGER_HOST=localhost
JAEGER_PORT=14268

# Cache
ENABLE_REDIS_CACHE=true
REDIS_URL=redis://localhost:6379
CACHE_TTL=60

# Environment
ATLAS_ENV=development
SERVICE_NAME=axiom-dev
SERVICE_VERSION=1.0.0-dev
