# AXIOM Testing Environment Configuration
# Este archivo contiene configuraciones específicas para el entorno de testing

# Server Configuration
DEBUG=false
RELOAD=false
HOST=127.0.0.1
PORT=8003

# Database Configuration
DATABASE_URL=postgresql://giovanniarangio@localhost:5432/axiom_test
ENABLE_DATABASE=true
DB_ECHO=false

# Logging
LOG_LEVEL=WARNING

# Security (Testing - configurado para tests)
ENABLE_AUTH_ROUTES=true
SECRET_KEY=test-secret-key-for-testing-only

# LLM Configuration
ENABLE_LOCAL_LLM=false
LLM_BACKEND=huggingface
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b
LLM_TEMPERATURE=0.1
LLM_MAX_NEW_TOKENS=256

# External APIs (Testing - mock o deshabilitado)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# Observability (Testing - mínimo)
ENABLE_OTEL=false
OTEL_SERVICE_NAME=axiom-test
JAEGER_ENABLED=false

# Cache
ENABLE_REDIS_CACHE=true
REDIS_URL=redis://localhost:6379/1
CACHE_TTL=10

# Environment
ATLAS_ENV=testing
SERVICE_NAME=axiom-test
SERVICE_VERSION=1.0.0-test

# Testing specific
AXIOM_SKIP_AUTOINIT=true
ASYNC_TOOL_TIMEOUT=5
ASYNC_TOOL_MAX_CONCURRENT=2
