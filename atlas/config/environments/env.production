# AXIOM Production Environment Configuration
# Este archivo contiene configuraciones específicas para el entorno de producción
# IMPORTANTE: Los secretos reales deben configurarse via variables de entorno del sistema

# Server Configuration
DEBUG=false
RELOAD=false
HOST=0.0.0.0
PORT=8002

# Database Configuration
DATABASE_URL=postgresql://axiom_prod_user:CHANGE_ME@prod-db:5432/axiom_production
ENABLE_DATABASE=true
DB_ECHO=false

# Logging
LOG_LEVEL=WARNING

# Security (Production - máximo nivel)
ENABLE_AUTH_ROUTES=true
SECRET_KEY=CHANGE_ME_PRODUCTION_SECRET_KEY_MIN_32_CHARS

# LLM Configuration
ENABLE_LOCAL_LLM=false
LLM_BACKEND=huggingface
OLLAMA_API_URL=http://ollama-prod:11434
OLLAMA_MODEL=mistral:7b
LLM_TEMPERATURE=0.1
LLM_MAX_NEW_TOKENS=256

# External APIs (Production - configurar con claves reales)
OPENAI_API_KEY=CHANGE_ME
GOOGLE_API_KEY=CHANGE_ME
ANTHROPIC_API_KEY=CHANGE_ME
MATERIALS_PROJECT_API_KEY=CHANGE_ME

# Observability (Production - completo)
ENABLE_OTEL=true
OTEL_SERVICE_NAME=axiom-production
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger-prod:4317
JAEGER_ENABLED=true
JAEGER_HOST=jaeger-prod
JAEGER_PORT=14268

# Cache
ENABLE_REDIS_CACHE=true
REDIS_URL=redis://redis-prod:6379
CACHE_TTL=600

# Environment
ATLAS_ENV=production
SERVICE_NAME=axiom-production
SERVICE_VERSION=1.0.0

# Production specific
MLFLOW_TRACKING_URI=http://mlflow-prod:5000
ECL_SIMULATION=false
LAB_SIMULATION=false
ASYNC_TOOL_TIMEOUT=30
ASYNC_TOOL_MAX_CONCURRENT=20
MAX_REQUEST_BYTES=10485760
