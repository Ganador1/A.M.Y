# AXIOM Staging Environment Configuration
# Este archivo contiene configuraciones específicas para el entorno de staging

# Server Configuration
DEBUG=false
RELOAD=false
HOST=0.0.0.0
PORT=8002

# Database Configuration
DATABASE_URL=postgresql://axiom_user:staging_password@staging-db:5432/axiom_staging
ENABLE_DATABASE=true
DB_ECHO=false

# Logging
LOG_LEVEL=INFO

# Security (Staging - más estricto que dev)
ENABLE_AUTH_ROUTES=true
SECRET_KEY=staging-secret-key-change-in-production

# LLM Configuration
ENABLE_LOCAL_LLM=false
LLM_BACKEND=huggingface
OLLAMA_API_URL=http://ollama-staging:11434
OLLAMA_MODEL=mistral:7b
LLM_TEMPERATURE=0.2
LLM_MAX_NEW_TOKENS=256

# External APIs (Staging - con límites)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# Observability (Staging - habilitado)
ENABLE_OTEL=true
OTEL_SERVICE_NAME=axiom-staging
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger-staging:4317
JAEGER_ENABLED=true
JAEGER_HOST=jaeger-staging
JAEGER_PORT=14268

# Cache
ENABLE_REDIS_CACHE=true
REDIS_URL=redis://redis-staging:6379
CACHE_TTL=300

# Environment
ATLAS_ENV=staging
SERVICE_NAME=axiom-staging
SERVICE_VERSION=1.0.0-staging

# Staging specific
MLFLOW_TRACKING_URI=http://mlflow-staging:5000
ECL_SIMULATION=true
LAB_SIMULATION=true
