# ========================================
# AXIOM ATLAS Environment Configuration
# ========================================

# ----------------------------------------
# Database Configuration
# ----------------------------------------
# PostgreSQL connection settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=axiom_meta4
DB_USER=atlas
DB_PASSWORD=your_secure_password_here

# Full database URL (alternative to individual settings)
# DATABASE_URL=postgresql://atlas:password@localhost:5432/axiom_meta4

# Database pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# ----------------------------------------
# Application Settings
# ----------------------------------------
# Environment: development, staging, production
ENV=development

# Secret key for session management and security
# IMPORTANT: Generate a secure key with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_secret_key_here

# Server settings
HOST=0.0.0.0
PORT=8000

# ----------------------------------------
# Redis Cache (Optional)
# ----------------------------------------
# Enable Redis caching for performance
ENABLE_REDIS_CACHE=false
REDIS_URL=redis://localhost:6379
REDIS_TTL=300

# Tool adapter cache settings
TOOL_ADAPTER_CACHE_SIZE=100
TOOL_ADAPTER_CACHE_TTL=300

# ----------------------------------------
# Async Tool Adapter Settings
# ----------------------------------------
ASYNC_TOOL_MAX_CONCURRENT=5
ASYNC_TOOL_TIMEOUT=30.0
ASYNC_TOOL_RETRY_ATTEMPTS=2
ASYNC_TOOL_RETRY_DELAY=1.0
ASYNC_TOOL_FAIL_FAST=false

# ----------------------------------------
# Validation Settings
# ----------------------------------------
# Path to validation database
VALIDATION_MATRIX_DB=./data/validation_matrix.db

# Retention and snapshot settings
VALIDATION_RETENTION_DAYS=30
VALIDATION_SNAPSHOT_INTERVAL=300

# ----------------------------------------
# External API Keys
# ----------------------------------------
# Materials Project API
MATERIALS_PROJECT_API_KEY=your_materials_project_api_key

# OpenAI API (if using external LLM)
# OPENAI_API_KEY=your_openai_api_key

# PubChem, UniProt, etc. (if required)
# PUBCHEM_API_KEY=your_pubchem_api_key
# UNIPROT_API_KEY=your_uniprot_api_key

# ----------------------------------------
# LLM Configuration (Ollama)
# ----------------------------------------
# Ollama server URL for local models
OLLAMA_BASE_URL=http://localhost:11434

# Default models for agents
ORCHESTRATOR_MODEL=llama3:8b
BIO_HYPOTHESIS_MODEL=mistral:7b
PHYSCHEM_CODER_MODEL=codellama:7b
REVIEWER_MODEL=qwen:7b
PUBLISHER_MODEL=llama3:8b

# ----------------------------------------
# Logging and Monitoring
# ----------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable OpenTelemetry tracing
ENABLE_OTEL=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ----------------------------------------
# Security Settings
# ----------------------------------------
# Enable JWT authentication (false for dev, true for production)
ENABLE_AUTH=false

# Enable ethics gate validation
ENABLE_ETHICS_GATE=true

# Enable risk assessment
ENABLE_RISK_ASSESSMENT=true

# Maximum request size (MB)
MAX_REQUEST_SIZE_MB=10

# JWT token expiration (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# User passwords (change in production!)
SYSTEM_ADMIN_PASSWORD=change_me_in_production
RESEARCHER_PASSWORD=change_me_in_production
LAB_OPERATOR_PASSWORD=change_me_in_production

# ----------------------------------------
# Performance Settings
# ----------------------------------------
# Enable lazy loading for routers
ENABLE_LAZY_LOADING=true

# Maximum workers for parallel processing
MAX_WORKERS=4

# ----------------------------------------
# Testing Configuration
# ----------------------------------------
# Use separate test database
TEST_DATABASE_URL=postgresql://atlas:password@localhost:5432/axiom_test

# Mock external APIs in tests
MOCK_EXTERNAL_APIS=true

# ----------------------------------------
# Feature Flags
# ----------------------------------------
# Enable experimental features
ENABLE_QUANTUM_COMPUTING=true
ENABLE_AUTONOMOUS_RESEARCH=true
ENABLE_MEDICAL_IMAGING=true

# ----------------------------------------
# Data Storage
# ----------------------------------------
# Path for data files
DATA_DIR=./data

# Path for model artifacts
MODELS_DIR=./models

# Path for experiment results
RESULTS_DIR=./results

# ----------------------------------------
# Backup and Disaster Recovery
# ----------------------------------------
# Enable automated backups
ENABLE_BACKUPS=false
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7
